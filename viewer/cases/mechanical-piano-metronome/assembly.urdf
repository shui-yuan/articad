<?xml version="1.0"?>
<robot name="Mechanical_piano_metronome">
  <link name="metronome_body">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="visual_meshes/metronome_body.glb" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
  </link>
  <link name="pendulum_rod">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="visual_meshes/pendulum_rod.glb" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
  </link>
  <link name="weight_slider">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <mesh filename="visual_meshes/weight_slider.glb" scale="0.001 0.001 0.001" />
      </geometry>
    </visual>
  </link>
  <joint name="Pendulum Swing" type="revolute">
    <parent link="metronome_body" />
    <child link="pendulum_rod" />
    <origin xyz="0.0475 0 0.04" rpy="0 0 0" />
    <axis xyz="1 0 0" />
    <limit lower="-0.436332313" upper="0.436332313" effort="1" velocity="1" />
  </joint>
  <joint name="Tempo Slider" type="prismatic">
    <parent link="pendulum_rod" />
    <child link="weight_slider" />
    <origin xyz="0 0 0.035" rpy="0 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="0" upper="0.07" effort="1" velocity="0.5" />
  </joint>
</robot>
