  <link name="steering_frame" />
  <joint name="Steering Turn" type="revolute">
    <parent link="frame" />
    <child link="steering_frame" />
    <origin xyz="0.55 0 0.75" rpy="0 -0.463647609 0" />
    <axis xyz="0 0 1" />
    <limit lower="-1.04719755" upper="1.04719755" effort="1" velocity="1" />
  </joint>
  <joint name="Steering Headset Offset" type="fixed">
    <parent link="steering_frame" />
    <child link="fork_and_handlebar" />
    <origin xyz="-0.827345152 0 -0.424852916" rpy="0 0.463647609 0" />
  </joint>
  <link name="front_wheel_spin_frame" />
  <joint name="Front Wheel Spin" type="revolute">
    <parent link="fork_and_handlebar" />
    <child link="front_wheel_spin_frame" />
    <origin xyz="0.75 0 0.35" rpy="-1.57079633 0 0" />
    <axis xyz="0 0 1" />
    <limit lower="-62.8318531" upper="62.8318531" effort="1" velocity="1" />
  </joint>
  <joint name="Front Wheel Axle Offset" type="fixed">
    <parent link="front_wheel_spin_frame" />
    <child link="front_wheel" />
    <origin xyz="-0.75 0.35 0" rpy="1.57079633 0 0" />
  </joint>
  <link name="rear_wheel_spin_frame" />
