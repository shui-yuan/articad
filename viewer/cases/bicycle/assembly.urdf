    <child link="rear_wheel" />
    <origin xyz="0.45 0.35 0" rpy="1.57079633 0 0" />
  </joint>
  <link name="crank_spin_frame" />
  <joint name="Crank Rotation" type="revolute">
    <parent link="frame" />
    <child link="crank_spin_frame" />
    <origin xyz="0 0 0.3" rpy="-1.57079633 0 0" />
    <axis xyz="0 0 1" />
